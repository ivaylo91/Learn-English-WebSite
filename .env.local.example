# Supabase — намери ги в: https://supabase.com/dashboard -> Project Settings -> API
# URL: само базовия домейн, без /rest/v1/ накрая
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — само за сървърни Server Actions (НИКОГА не се излага клиентски)
# Намери го в: Supabase Dashboard -> Project Settings -> API -> service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Comma-separated list of admin emails (server-side only, no NEXT_PUBLIC_ prefix)
ADMIN_EMAILS=ipenev91@gmail.com

# Public site URL — used for building absolute links in emails (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Resend — https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# The "from" address must be a verified domain in Resend
RESEND_FROM_EMAIL=Учи Английски <noreply@your-domain.com>

# Secret for protecting the /api/cron/streak-reminder endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Secret for signing one-click unsubscribe tokens
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=your-unsubscribe-secret-here

# Web Push / VAPID keys — generate once with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is exposed to the browser (safe — it's a public key)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
# Use mailto: or your site URL
VAPID_SUBJECT=mailto:hello@your-domain.com
